<AddIn name="Clarion Assistant" author="John Hickey" description="AI-powered Clarion IDE assistant: embedded Claude Code terminal, MCP tools, LSP integration, CodeGraph, and IDE automation">
  <Manifest>
    <Identity name="ClarionAssistant" version="@VERSION@"/>
    <!-- NO manifest <Dependency> on ClarionLsp. On this SharpDevelop/Clarion build a declared
         <Dependency> is enforced as HARD-REQUIRED — the addin fails to load entirely when ClarionLsp
         is absent ("requires ClarionLsp, version 1.0") — even with coerced="true". We therefore
         consume the shared addin PURELY AT RUNTIME via ClarionLspLocator.Current (see SharedLspBridge),
         which resolves per-call and falls back to the bundled LspClient when ClarionLsp isn't present.
         Load order is not guaranteed; LspAutostartCommand's fallback timer reconciles the start race
         (it stops our bundled server if the shared one appears after we started ours). -->
  </Manifest>
  <Runtime>
    <Import assembly="ClarionAssistant.dll"/>
  </Runtime>

  <!-- Start the Clarion LSP early and independent of any pad (see LspAutostartCommand). -->
  <Path name="/Workspace/Autostart">
    <!-- FIRST: install the CWBinding/CommonSources version-agnostic AssemblyResolve shim BEFORE any
         source file's DisplayBinding is built. CommonSources.dll is strong-named, so our binding
         subclass otherwise fails to load on any C12 build != the one we compiled against
         ("Cannot create object: MonacoClarionEditorDisplayBinding", ticket 0abd79df). -->
    <Class id="ClarionAssistantBindingResolver" class="ClarionAssistant.ClarionBindingAssemblyResolverCommand"/>
    <Class id="ClarionAssistantStartLsp" class="ClarionAssistant.LspAutostartCommand"/>
    <!-- Poll-detect: auto-attach the live CA Embeditor overlay when a native PWEE embed opens, incl. via
         Clarion's own "Embeditor Source" menu (ticket 4d16b53a, see EmbedEditorMonitorService). Replaced the
         old right-click "Open in CA Embeditor" native-menu-injection hook (ticket 4b82f1de, retired 4d16b53a). -->
    <Class id="ClarionAssistantStartEmbedMonitor" class="ClarionAssistant.EmbedEditorMonitorAutostartCommand"/>
    <!-- Arm the ApplicationExit shutdown backstop unconditionally (not gated on the chat MCP server). -->
    <Class id="ClarionAssistantArmShutdown" class="ClarionAssistant.ShutdownAutostartCommand"/>
  </Path>

  <!-- Ordered addin teardown at shutdown. Our heavy teardown (stop MCP, kill ConPty child trees, dispose
       WebView2 on the UI thread) runs FIRST so Clarion can close cleanly; then the right-click hook unhooks. -->
  <Path name="/Workspace/Terminate">
    <Class id="ClarionAssistantTerminateShutdown" class="ClarionAssistant.ShutdownTerminateCommand"/>
    <Class id="ClarionAssistantTerminateEmbedMonitor" class="ClarionAssistant.EmbedEditorMonitorTerminateCommand"/>
  </Path>

  <Path name="/SharpDevelop/Workbench/Pads">
    <Pad id="ClassHelper" category="Tools" title="Class Helper"
         icon="PadIcons.ClassBrowser" shortcut="Control|Alt|M"
         class="ClarionAssistant.ClassHelperPad"/>
    <Pad id="ClaudeChat" category="Tools" title="Clarion Assistant v@VERSION@"
         icon="PadIcons.Output" shortcut="Control|Alt|C"
         class="ClarionAssistant.ClaudeChatPad"/>
    <Pad id="AgentPanel" category="Tools" title="Agent Panel"
         icon="PadIcons.TaskList" shortcut="Control|Alt|A"
         class="ClarionAssistant.AgentPanelPad"/>
    <Pad id="ModernData" category="Tools" title="CA Explorer"
         icon="PadIcons.Output" shortcut="Control|Alt|D"
         class="ClarionAssistant.ModernDataPad"/>
  </Path>

  <Path name="/Workspace/Tools">
    <MenuItem id="ShowClassHelper" label="Class Helper"
              class="ClarionAssistant.ShowClassHelperCommand"/>
    <MenuItem id="ShowClaudeChat" label="Clarion Assistant"
              class="ClarionAssistant.ShowClaudeChatCommand"/>
    <MenuItem id="ShowAgentPanel" label="Agent Panel"
              class="ClarionAssistant.ShowAgentPanelCommand"/>
    <MenuItem id="ShowModernDataPad" label="CA Explorer"
              class="ClarionAssistant.ShowModernDataPadCommand"/>
  </Path>

  <!-- CA Embeditor button on the native embeditor toolbar. -->
  <Path name="/SoftVelocity/Clarion/ToolBar/EmbedEditor">
    <ToolbarItem id="ShowModernEmbeditor" label="CA Embeditor"
                 tooltip="Path B: open the assembled embeditor source in a modern Monaco editor (read-only render)"
                 class="ClarionAssistant.ShowModernEmbeditorCommand"/>
  </Path>

  <!-- SPIKE (task cc8b092f): make our ClarionEditor subclass the DEFAULT editor for Clarion
       source files, winning the binding race ahead of the stock ClarionWinEditor via insertbefore.
       Mirrors the stock primary binding exactly (same supportedformats, no fileNamePattern); the
       real gate is the inherited CanCreateContentForFile (Clarion source extensions). Phase 0 is
       behaviorally IDENTICAL to the stock editor (subclass only logs + returns a real ClarionEditor),
       so this is safe to ship; Phase 1 adds the Monaco overlay. To disable: remove this Path. -->
  <Path name="/SharpDevelop/Workbench/DisplayBindings">
    <DisplayBinding id="MonacoClarionEditor"
                    insertbefore="ClarionWinEditor"
                    supportedformats="Text Files,Source Files"
                    class="ClarionAssistant.MonacoClarionEditorDisplayBinding"/>
  </Path>

  <!-- IDE Options pane (ticket 1c0862e1): Options > Clarion Assistant > Editor Surfaces.
       Per-surface toggles to disable the Monaco source-editor / embeditor replacements.
       Same SharpDevelop mechanism the 3rd-party "Upper Park Solutions" pane uses: the OUTER
       <DialogPanel> (no class) is the tree GROUP node; the INNER one (class=...) is the pane.
       Panel persists via CaEditorSettings (settings.txt); read at editor/embeditor attach time. -->
  <Path name="/SharpDevelop/Dialogs/OptionsDialog">
    <DialogPanel id="ClarionAssistantOptions" label="Clarion Assistant">
      <DialogPanel id="CAEditorSurfaces" label="Editor Surfaces"
                   class="ClarionAssistant.Options.CAEditorSurfacesOptionPanel"/>
    </DialogPanel>
  </Path>
</AddIn>
