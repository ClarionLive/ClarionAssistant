<Project>
  <!--
    Single source of truth for ClarionAssistant version.

    VersionBuild auto-increments on every MSBuild compile (see PrebuildVersion target in csproj).
    To bump VersionMajor or VersionMinor (or set VersionBuild manually), run:
        .\Bump-Version.ps1 -Major 4 -Minor 7
        .\Bump-Version.ps1 -Build 12345
  -->
  <PropertyGroup>
    <VersionMajor>5</VersionMajor>
    <VersionMinor>1</VersionMinor>
    <VersionBuild>621</VersionBuild>
    <FullVersion>5.1.621</FullVersion>
    <AssemblyFullVersion>5.1.621.0</AssemblyFullVersion>
  </PropertyGroup>
</Project>