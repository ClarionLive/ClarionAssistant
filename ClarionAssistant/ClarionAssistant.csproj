    <!-- SoftVelocity-internal Clarion editor + designer classes. Needed to SUBCLASS
         CWBinding.ClarionEditor.ClarionEditor (Monaco-default-editor spike, task cc8b092f):
         the structure designer's Ctrl+D gate requires an is-a TextEditorDisplayBindingWrapper
         + IStructureDesignerCompatible, which only a ClarionEditor subclass satisfies. These
         are version-brittle internals -> resolved per Clarion version via $(ClarionRoot). -->
    <Reference Include="CWBinding">
      <HintPath>$(ClarionRoot)\bin\Addins\BackendBindings\ClarionBinding\ClarionWin\CWBinding.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="CommonSources">
      <HintPath>$(ClarionRoot)\bin\Addins\BackendBindings\ClarionBinding\Common\CommonSources.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- Old-style csproj + PackageReference is inconsistent under dotnet/msbuild for this project.
         Add explicit WebView2 references so compile-time assemblies are always resolved after restore. -->
    <Reference Include="Microsoft.Web.WebView2.Core">
      <HintPath>$(PkgMicrosoft_Web_WebView2)\lib\net462\Microsoft.Web.WebView2.Core.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="Microsoft.Web.WebView2.WinForms">
      <HintPath>$(PkgMicrosoft_Web_WebView2)\lib\net462\Microsoft.Web.WebView2.WinForms.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <!-- Shared Clarion LSP contract (msarson/clarion-lsp v1.1.0). We ship our own copy of
         the contract DLL (Private=True) and consume the live IClarionLanguageClient through
         ClarionLspLocator.Current when the ClarionLsp addin is installed; otherwise we fall
         back to our bundled LspClient. The .addin declares a soft (coerced) dependency on it. -->
    <Reference Include="ClarionLsp.Contracts">
      <HintPath>lib\ClarionLsp\ClarionLsp.Contracts.dll</HintPath>
      <Private>True</Private>
    </Reference>
  </ItemGroup>
