  <!--
    PrebuildVersion: runs Update-Version.ps1 before compile. Increments VersionBuild in
    Version.props and regenerates Properties\AssemblyVersion.cs and ClarionAssistant.addin
    from Version.props + ClarionAssistant.addin.template. Skipped for design-time/restore-only
    builds (no Configuration set) so editing inside IDEs doesn't spin the build counter.
  -->
  <Target Name="PrebuildVersion" BeforeTargets="CoreCompile" Condition="'$(Configuration)' != '' and '$(DesignTimeBuild)' != 'true' and '$(BuildingInsideVisualStudio)' != 'true'">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)Update-Version.ps1&quot;"
          WorkingDirectory="$(MSBuildThisFileDirectory)" />
  </Target>

  <!--
    EnsureVersionFiles: cheap safety net for fresh checkouts. If AssemblyVersion.cs or
    ClarionAssistant.addin are missing (gitignored, never built locally), generate them
    WITHOUT incrementing the build counter so the compile can resolve them.
  -->
  <Target Name="EnsureVersionFiles" BeforeTargets="PrebuildVersion;ValidateClarionReferences"
          Condition="!Exists('$(MSBuildThisFileDirectory)Properties\AssemblyVersion.cs') Or !Exists('$(MSBuildThisFileDirectory)ClarionAssistant.addin')">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)Update-Version.ps1&quot; -NoIncrement"
          WorkingDirectory="$(MSBuildThisFileDirectory)" />
  </Target>

  <Target Name="ValidateClarionReferences" BeforeTargets="ResolveReferences">
    <Error Condition="'$(ClarionRoot)' == ''"
           Text="ClarionRoot is not set. Create Directory.Build.props.user or pass /p:ClarionRoot=C:\Path\To\Clarion." />
    <Error Condition="!Exists('$(ClarionRoot)\bin\ICSharpCode.Core.dll')"
           Text="Missing Clarion dependency: $(ClarionRoot)\bin\ICSharpCode.Core.dll. Set ClarionRoot to your Clarion installation folder." />
    <Error Condition="!Exists('$(ClarionRoot)\bin\ICSharpCode.SharpDevelop.dll')"
           Text="Missing Clarion dependency: $(ClarionRoot)\bin\ICSharpCode.SharpDevelop.dll. Set ClarionRoot to your Clarion installation folder." />
  </Target>
