bin/
obj/
*.user
*.suo
.vs/
*.pdb
packages/

# Installer output and large binaries (release assets, not repo content)
installer/output/
installer/docgraph.db
installer/preview-icon.png

# FTS5-enabled SQLite binaries (required, not available via NuGet)
!ClarionAssistant/lib/sqlite-fts5/*.dll

# VoidTools Everything SDK (runtime dependency)
!ClarionAssistant/Everything32.dll

# Claude Code local settings
ClarionAssistant/.claude/settings.local.json
ClarionAssistant/.claude/continuation.md

# Project-level Claude config (dev-specific)
.claude/project.json

# Debug stderr captures from the embedded assistant
stderr_*.txt

# Generated by Update-Version.ps1 (regenerated from Version.props on every build)
ClarionAssistant/ClarionAssistant.addin
ClarionAssistant/Properties/AssemblyVersion.cs

# Sibling project that lives alongside the repo (not part of ClarionAssistant)
/DatePickerWebviewCOM/

# Local Clarion deploy target written by the sibling project's build
/Clarion/

# Local runtime knowledge-base SQLite (per-dev data, not repo content)
ClarionAssistant/knowledge.db

# Transient MultiTerminal task worktrees
.claude/worktrees/

# Pinned-tag LSP build cache (fetched + built by deploy.ps1, GitHub #40)
ClarionAssistant/.lsp-build/
